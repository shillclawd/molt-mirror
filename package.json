{
  "name": "moltmirror",
  "version": "0.1.0",
  "description": "Self-referential meta agent that observes Moltbook, reflects, and posts back",
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "DRY_RUN=true tsx src/index.ts --once",
    "dev:post": "tsx src/index.ts --once",
    "loop": "tsx src/index.ts",
    "loop:dry": "DRY_RUN=true tsx src/index.ts",
    "memory:show": "tsx src/scripts/show-memory.ts",
    "memory:reset": "tsx src/scripts/reset-memory.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.4.0",
    "node-cron": "^3.0.3",
    "openai": "^6.33.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20"
  }
}
